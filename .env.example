# ═══════════════════════════════════════════════════════════════
#  MCP-сервер стандартов 1С — конфигурация
#  Скопируйте в .env и заполните нужные значения:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Авторизация на its.1c.ru ──────────────────────────────────
# Для загрузки полной базы стандартов нужна подписка ИТС.
ITS_LOGIN=
ITS_PASSWORD=

# ── Загрузка стандартов ───────────────────────────────────────
# Загружать ли полную базу с its.1c.ru при старте контейнера
# true  — скачать стандарты (нужны ITS_LOGIN + ITS_PASSWORD)
# false — использовать встроенную базу (~15 ключевых стандартов)
SCRAPE_ON_START=false

# Принудительная перезагрузка даже если база уже скачана
FORCE_RESCRAPE=false

# ── Пользовательские стандарты ────────────────────────────────
# Путь к вашим стандартам внутри контейнера (монтируется через volume)
# Оставьте пустым, если не нужны
CUSTOM_STANDARDS_PATH=

# Путь к директории с вашими стандартами НА ХОСТЕ
# Используется в docker-compose для монтирования volume
CUSTOM_STANDARDS_DIR=./custom-standards

# ── Сеть ──────────────────────────────────────────────────────
# Порт HTTP-сервера (на хосте)
MCP_PORT=3000
